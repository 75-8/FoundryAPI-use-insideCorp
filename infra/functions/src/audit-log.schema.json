{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex audit log record",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "oid", "promptTokens", "completionTokens", "totalTokens", "httpStatus", "requestId"],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "oid": { "type": "string" },
    "tid": { "type": "string" },
    "sub": { "type": "string" },
    "appid": { "type": "string" },
    "azp": { "type": "string" },
    "model": { "type": "string" },
    "deployment": { "type": "string" },
    "operation": { "type": "string" },
    "promptTokens": { "type": "integer", "minimum": 0 },
    "completionTokens": { "type": "integer", "minimum": 0 },
    "totalTokens": { "type": "integer", "minimum": 0 },
    "httpStatus": { "type": "integer" },
    "backendStatus": { "type": "integer" },
    "latencyMs": { "type": "integer", "minimum": 0 },
    "backendLatencyMs": { "type": "integer", "minimum": 0 },
    "requestId": { "type": "string" },
    "correlationId": { "type": "string" },
    "traceparent": { "type": "string" },
    "clientIp": { "type": "string" },
    "userAgent": { "type": "string" },
    "xMsClientRequestId": { "type": "string" },
    "xMsRequestId": { "type": "string" }
  }
}
